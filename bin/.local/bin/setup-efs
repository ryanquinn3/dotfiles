#!/usr/bin/env bash
 # Creates ~/X → ~/efs/X symlinks for persistent state across devcontainers.
 # Safe to re-run: skips already-correct symlinks, migrates real dirs/files to efs first.

 EFS_DIR="$HOME/efs"

 if [ ! -d "$EFS_DIR" ]; then
   echo "setup-efs: ~/efs not found, skipping"
   exit 0
 fi

 link_to_efs() {
   local name="$1"
   local src="$HOME/$name"
   local dst="$EFS_DIR/$name"

   # Already correct
   if [ -L "$src" ] && [ "$(readlink "$src")" = "$dst" ]; then
     return
   fi

   # Migrate real file/dir to efs if dst doesn't exist yet
   if [ ! -e "$dst" ] && [ -e "$src" ] && [ ! -L "$src" ]; then
     mv "$src" "$dst"
   fi

   # Remove stale real file/dir at src
   if [ -e "$src" ] && [ ! -L "$src" ]; then
     rm -rf "$src"
   fi

   # Remove wrong symlink
   [ -L "$src" ] && rm "$src"

   mkdir -p "$(dirname "$src")"
   ln -s "$dst" "$src"
 }

link_to_efs "$1"
