#!/usr/bin/env zsh

DIR=$(cd `dirname $0` && pwd)

function configure_screenshot_storage(){
	# Setup the screenshots directory and have the OS store all screenshots there
	[ ! -d ~/screenshots ] && mkdir ~/screenshots
	defaults write com.apple.screencapture location ~/screenshots
	defaults write com.apple.screencapture "show-thumbnail" -bool "false" 
	killall SystemUIServer
}

function configure_dock_settings(){
	defaults write com.apple.dock "autohide" -bool "true"
	defaults write com.apple.dock "orientation" -string "left"
	defaults write com.apple.dock expose-group-apps -bool true
	killall Dock
}

function configure_finder() {
	defaults write com.apple.finder "ShowPathbar" -bool "true" && killall Finder
}

function tmux_plugin_path() {
	local plugin_name="$1"
	echo "$HOME/.tmux/plugins/$plugin_name"
}

function setup_tmux() {
	mkdir -p ~/.tmux/plugins

	if [ -d "$(tmux_plugin_path tpm)" ]; then
		echo "tpm already installed"
	else
		git clone https://github.com/tmux-plugins/tpm "$(tmux_plugin_path tpm)"
	fi

	if [ -d "$(tmux_plugin_path catppuccin)" ]; then
		echo "catppuccin already installed"
	else
		mkdir -p "$(tmux_plugin_path catppuccin)"
		git clone -b v2.3.0 https://github.com/catppuccin/tmux.git "$(tmux_plugin_path catppuccin)/tmux"
	fi
}


### Oh My Zsh
function setup_oh_my_zsh_plugins() {
	custom_plugins_dir="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/plugins"
	[ -d "$custom_plugins_dir" ] || mkdir -p "$custom_plugins_dir"

	source "$DIR/zsh/.zsh/shell.zsh"
	
	install_plugin "fzf-zsh-plugin" "https://github.com/unixorn/fzf-zsh-plugin.git"
	install_plugin "fzf-tab" "https://github.com/Aloxaf/fzf-tab.git"
	install_plugin "zsh-yarn-completions" "https://github.com/chrisands/zsh-yarn-completions.git"
	install_plugin "zsh-syntax-highlighting" "https://github.com/zsh-users/zsh-syntax-highlighting.git"
	install_plugin "zsh-autosuggestions" "https://github.com/zsh-users/zsh-autosuggestions.git"
	
}

function setup_oh_my_zsh() {
	mkdir -p ~/.zsh/completions
	if [ -d ~/.oh-my-zsh ]; then
			echo "Oh my zsh is already installed"
	else
	  echo "Installing Oh My Zsh..."
		sh -c "$(curl -fsSL https://raw.github.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
	fi
	
	setup_oh_my_zsh_plugins
}

### end Oh My Zsh

function install_homebrew_for_linux(){
	if command -v brew >/dev/null 2>&1; then
		echo "Homebrew already installed"
	else
		/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
	fi
	sudo apt-get install build-essential
	eval $(/home/linuxbrew/.linuxbrew/bin/brew shellenv)
	# needed for this install script
	HOMEBREW_NO_AUTO_UPDATE=1 brew install stow fzf
	
	# gh extension install dlvhdr/gh-dash
}


setup_tmux


if [[ $OSTYPE == 'darwin'* ]]; then
	stow -t "$HOME" aerospace
  echo -ne "Updating MacOS UI config...\033[0K\r"
  configure_screenshot_storage
  configure_dock_settings
  configure_finder
  echo -e "Updating MacOS UI config... Done"
fi

if [[ $OSTYPE == 'linux-gnu'* ]]; then
	echo -ne "Installing homebrew...\033[0K\r"
	install_homebrew_for_linux
	mkdir -p ~/.fzf/shell
	ln -sf /usr/share/doc/fzf/examples/key-bindings.zsh ~/.fzf/shell/key-bindings.zsh
	
fi


echo "Symlinking dotfiles..."

# remove pre-existing rc files so stow can symlink ours without conflict.
# skip files we already symlinked (stow re-runs), and never clobber an existing backup.
backup_rc_file() {
	local rc="$1"
	[ -e "$rc" ] || return 0          # nothing there
	[ -L "$rc" ] && return 0          # already our stow symlink
	[ -e "$rc.old" ] && return 0      # keep the original backup
	mv "$rc" "$rc.old"
}
backup_rc_file "$HOME/.zshrc"
backup_rc_file "$HOME/.zshenv"

./stow.sh
setup_oh_my_zsh


# make sure default shell is set to zsh
zsh_path=$(which zsh)
if [ "$SHELL" != "$zsh_path" ]; then
	sudo chsh -s "$zsh_path" "$USER"
fi


echo "Run \"source ~/.zshrc\" to load the new zsh config."

