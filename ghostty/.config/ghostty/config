# Font settings
font-family = "JetBrains Mono"
font-size = 13

command = /usr/bin/env zsh
shell-integration-features = ssh-env
macos-option-as-alt = left

copy-on-select = clipboard
clipboard-read = allow
clipboard-write = allow

# tmux remappers
# ctrl+s = \x13

# macos-titlebar-style = hidden

keybind = super+s=text:\x1b[115;8u

# cmd+escape => F35 which tmux is wired up to receive
keybind = super+escape=text:\x1b[1;5P

# cmd+k => custom sequence tmux maps to User0 (fzf window switcher popup)
keybind = super+k=text:\x1b[5002~

# cmd+k => custom sequence tmux maps to User0 (fzf window switcher popup)
keybind = super+e=text:\x1b[5003~

desktop-notifications = true

# switch windows (1-4)
# keybind = super+1=unbind
keybind = ctrl+one=text:\x13\x31
keybind = ctrl+two=text:\x13\x32
keybind = ctrl+three=text:\x13\x33
keybind = ctrl+four=text:\x13\x34

# split pane vertical
keybind = super+\=text:\x13\x7c

# close pane
keybind = super+w=text:\x13\x78

minimum-contrast = 1.2
keybind = shift+enter=text:\x1b\r
