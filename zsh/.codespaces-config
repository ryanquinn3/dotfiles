# Fast turbo task runner with fzf selection
# Caches task list in temp file for performance
# Output format: $PACKAGE_NAME#$TASK_NAME
# Ignores the "//" package
# To refresh cache: rm /tmp/.turbo_tasks_cache
function _run_turbo_task() {
  local cache_file="/tmp/.turbo_tasks_cache"

  # Check if cache exists
  if [[ -f "$cache_file" ]]; then
    # Use cached tasks
    local flat_tasks
    flat_tasks=$(<"$cache_file")
  else
    # Generate fresh task list and cache it
    local task_json
    # pipe stderr to /dev/null to avoid noisy output
    task_json=$(turbo query "query { packages { items { name tasks { items { name} }} } }" 2>/dev/null)

    local flat_tasks
    flat_tasks=$(echo "$task_json" | jq -r '.data.packages.items[] | select(.name != "//") | .name as $pkg | .tasks.items[].name | "\($pkg)#\(.)"')

    # Cache the result
    echo "$flat_tasks" > "$cache_file"
  fi

  # Use fzf to select and run task
  local selected_task
  selected_task=$(print -r -- "$flat_tasks" | fzf)
  # tasks will look like "@vanta/{package}#{task-name}"
  # want to run turbo $TASK_NAME --filter=@vanta/{package}
  TASK_NAME="${selected_task##*#}"
  PACKAGE_NAME="${selected_task%%#*}"
   if [[ -n "$selected_task" ]]; then

    # what you actually execute (properly quoted)
    local command="turbo "$TASK_NAME" --filter="$PACKAGE_NAME" --output-logs=\"errors-only\""
    eval $command
    
    print -s -- "$command"        # append to zsh history without expansion
  fi
}

function _run_just(){
  recipe=$(just | bat | fzf | awk '{ print $1 }')
   history -s "just $recipe"
  just $recipe
}

function dev-workspace-archive(){
  mkdir -p "$DEV_ARCHIVE_DIR"

  (
    cd /workspaces/obsidian
    local dirs=()
    while IFS= read -r d; do
      dirs+=("$d")
    done < <(find . -type d -name ".ai-dev" | sed 's|^\./||')

    if [[ ${#dirs[@]} -eq 0 ]]; then
      echo "No .ai-dev directories found"
      return 1
    fi

    zmodload zsh/stat
    local latest_mtime=0
    local m
    while IFS= read -r -d '' f; do
      m=$(zstat +mtime "$f")
      (( m > latest_mtime )) && latest_mtime=$m
    done < <(find "${dirs[@]}" -type f -print0)
    local timestamp=$(strftime '%Y-%m-%dT%H-%M-%S' "$latest_mtime")
    local archive="$DEV_ARCHIVE_DIR/${timestamp}.tar.gz"

    if [[ -f "$archive" ]]; then
      echo "$archive"
      return 0
    fi

    tar czf "$archive" --exclude="node_modules" "${dirs[@]}"
    ln -sf "$archive" "$DEV_ARCHIVE_DIR/latest"
    echo "$archive"
  )
}

function dev-workspace-push(){
  local archive
  archive=$(dev-workspace-archive)
  if [[ $? -ne 0 ]]; then
    echo "Archive failed"
    return 1
  fi

  local filename=$(basename "$archive")
  aws-vault exec devadmin -- aws s3 cp "$archive" "$DEV_S3_ARCHIVE_PREFIX/$filename"
}

function dev-workspace-pull(){
  mkdir -p "$DEV_ARCHIVE_DIR"

  local latest_key
  latest_key=$(aws-vault exec devadmin -- aws s3 ls "$DEV_S3_ARCHIVE_PREFIX/" | sort | tail -1 | awk '{print $4}')
  if [[ -z "$latest_key" ]]; then
    echo "No archives found in S3"
    return 1
  fi

  local dest="$DEV_ARCHIVE_DIR/$latest_key"
  aws-vault exec devadmin -- aws s3 cp "$DEV_S3_ARCHIVE_PREFIX/$latest_key" "$dest"
  ln -sf "$dest" "$DEV_ARCHIVE_DIR/latest"

  (cd /workspaces/obsidian && tar xzf "$dest")
  echo "Restored from $latest_key"
}


