#!/usr/bin/env bash
# Catppuccin Macchiato themed bar with two floating pills (left + right).
# Docs: https://felixkratz.github.io/SketchyBar/

PLUGIN_DIR="$CONFIG_DIR/plugins"

source "$PLUGIN_DIR/colors.sh"

BAR_HEIGHT=32
PILL_HEIGHT=26
PILL_RADIUS=13 # half of PILL_HEIGHT for a true pill shape

##### Bar Appearance #####
# Fully transparent bar so the left/right brackets read as isolated pills.
sketchybar --bar position=top \
                 height=$BAR_HEIGHT \
                 color=0x00000000 \
                 blur_radius=0 \
                 padding_left=8 \
                 padding_right=8 \
                 y_offset=0 \
                 margin=0

##### Changing Defaults #####
default=(
  padding_left=4
  padding_right=4
  icon.font="Hack Nerd Font:Bold:14.0"
  label.font="Hack Nerd Font:Bold:12.0"
  icon.color=$TEXT
  label.color=$TEXT
  icon.padding_left=4
  icon.padding_right=4
  label.padding_left=4
  label.padding_right=4
)
sketchybar --default "${default[@]}"

##### Mission Control Space Indicators #####
sketchybar --add event aerospace_workspace_change

# Single indicator: workspace icon on the left, focused workspace name on the right.
sketchybar --add item workspace left \
           --subscribe workspace aerospace_workspace_change \
           --set workspace \
                 icon=î­ż\
                 icon.color=$ACCENT \
                 label.color=$TEXT \
                 script="$CONFIG_DIR/plugins/aerospace.sh"

##### Left Items #####
sketchybar --add item front_app left \
           --set front_app icon.drawing=off label.color=$TEXT \
                 script="$PLUGIN_DIR/front_app.sh" \
           --subscribe front_app front_app_switched

##### Right Items #####
sketchybar --add item clock right \
           --set clock update_freq=10 icon= icon.color=$LAVENDER \
                 script="$PLUGIN_DIR/clock.sh" \
           --add item volume right \
           --set volume icon.color=$SKY script="$PLUGIN_DIR/volume.sh" \
           --subscribe volume volume_change \
           --add item battery right \
           --set battery update_freq=120 icon.color=$GREEN \
                 script="$PLUGIN_DIR/battery.sh" \
           --subscribe battery system_woke power_source_change

sketchybar --add item tailscale right \
           --set tailscale script="$PLUGIN_DIR/tailscale.sh" \
                 update_freq=10 \
                 label.padding_left=0 \
                 label.padding_right=0 \
                 icon=ó°¦ť \
                 label.font="Hack Nerd Font:Regular:11.0"

##### Pills (brackets) #####
# Left pill groups the workspaces + front_app; right pill groups the status items.
pill=(
  background.color=$PILL_BG
  background.corner_radius=$PILL_RADIUS
  background.height=$PILL_HEIGHT
  background.border_color=$PILL_BORDER
  background.border_width=1
  padding_left=8
      padding_right=8
)

sketchybar --add bracket left_pill workspace front_app \
           --set left_pill "${pill[@]}"

sketchybar --add bracket right_pill clock volume battery tailscale \
           --set right_pill "${pill[@]}"

##### Force all scripts to run the first time #####
sketchybar --update
