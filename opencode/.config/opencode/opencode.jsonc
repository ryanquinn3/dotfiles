{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [],
  "agent": {
    "thinker": {
      "model": "openai/gpt-5.5",
      "permission": {
        "edit": "ask",
      }
    },
    "plan": {
      "model": "openai/gpt-5.5",
      "permission": {
        "edit": "ask",
      }
    },
    
    "build": {
      "model":"openai/gpt-5.4"
    }
  },
  "lsp": true,
  "mcp": {
  "context7": {
    "type": "remote",
    "url": "https://mcp.context7.com/mcp",
    "enabled": true
  }
},
  "permission": {
    "skill": {
      "*": "allow",
      "quality-check": "deny",
      "technical-documentation": "deny",
      "humanizer":"deny"
    }
  }
}
